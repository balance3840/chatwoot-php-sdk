# Copy this file to .env.integration and fill in your values.

# Required for all integration tests
CHATWOOT_BASE_URL=https://chat.example.com
CHATWOOT_API_TOKEN=your_agent_api_access_token
CHATWOOT_ACCOUNT_ID=1

# Required for conversation and assignment tests
# Find the inbox ID at Settings → Inboxes
CHATWOOT_INBOX_ID=3

# Required for Client API tests
# Find the inbox identifier at Settings → Inboxes → [your inbox] → Collaboration tab
CHATWOOT_INBOX_IDENTIFIER=your_inbox_identifier_string

# Required for Platform API tests (self-hosted only)
# Find or create a Platform App at Super Admin Console → Platform Apps
CHATWOOT_PLATFORM_TOKEN=your_platform_app_token
